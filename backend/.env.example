# Copy to .env for local development and adjust values.

# Core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://tuna:tuna@localhost:5432/tuna

# CORS / CSRF — the React dev server origin (Vite defaults to 5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Email
DJANGO_DEFAULT_FROM_EMAIL=no-reply@tuna.local

# Production-only SMTP (not needed for local console email)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
